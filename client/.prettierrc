{
  "$schema": "http://json.schemastore.org/prettierrc",
  "printWidth": 100,
  "quoteProps": "consistent",
  "semi": true,
  "singleQuote": true,
  "arrowParens": "always",
  "tabWidth": 2,
  "trailingComma": "all",
  "endOfLine": "auto",
  "overrides": [
    {
      "files": ["*.json", "*.yml", "*.md"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": ["*.{ts,tsx}"],
      "options": {
        "parser": "typescript"
      }
    }
  ]
}
